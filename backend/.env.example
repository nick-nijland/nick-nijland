# SMTP — use Resend, Brevo, or Gmail app password
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=your_api_key_here

# Must be an address on your verified domain (e.g. no-reply@nicknijland.nl)
SMTP_FROM_EMAIL=no-reply@nicknijland.nl

# The email address where contact form messages will be delivered
CONTACT_RECEIVER_EMAIL=nijlandnick@gmail.com

# URL of the Angular frontend (used for CORS)
FRONTEND_URL=http://localhost:4200,https://www.nicknijland.nl,https://nicknijland.nl
